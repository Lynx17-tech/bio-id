<?xml version='1.0' encoding='utf-8'?>
<widget id="com.bioid.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>BioID</name>
    <description>BioID Biometric Recognition System for Vehicular Accident</description>
    <author email="support@bioid.com" href="http://bioid.com">Bernie Jay Manalo</author>
    <content src="index.html" />
    
    <preference name="ScrollEnabled" value="false" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="BackupWebStorage" value="none" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    
    <plugin name="cordova-plugin-usbserial" spec="~0.6.0" />
    <plugin name="cordova-plugin-whitelist" spec="1" />
    
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    
    <platform name="android">
        <allow-intent href="market:*" />
        <icon src="www/images/favicon.png" />
    </platform>
</widget>
